  "apiContracts": [
    {
      "method": "POST",
      "path": "/api/v1/intake",
      "description": "Upload media file for multi-modal processing",
      "auth": {
        "required": true,
        "provider": "Firebase Auth",
        "method": "Bearer JWT in Authorization header"
      },
      "rateLimit": "30/min",
      "request": {
        "contentType": "multipart/form-data",
        "fields": {
          "media": {
            "type": "file",
            "required": true,
            "description": "Audio/video/image file"
          },
          "metadata": {
            "type": "JSON string",
            "required": true,
            "schema": "IntakeMetadataSchema"
          }
        }
      },
      "responses": {
        "202": {
          "description": "Accepted for processing",
          "body": {
            "event_id": "string (uuid)",
            "status": "PROCESSING",
            "tracking_url": "string"
          }
        },
        "400": {
          "code": "VALIDATION_ERROR",
          "description": "Missing file or invalid metadata"
        },
        "401": {
          "code": "UNAUTHORIZED",
          "description": "Missing or invalid Firebase Auth token"
        }
      }
    }
  ],
  "testSpecifications": {
