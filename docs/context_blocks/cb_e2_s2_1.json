  "techStack": {
    "runtime": {
      "language": "TypeScript",
      "version": "5.x"
    },
    "additionalLibraries": [
      {
        "name": "@google-cloud/vertexai",
        "version": "1.x",
        "purpose": "Vertex AI SDK for Gemini 1.5 Pro multi-modal reasoning"
      }
    ]
  },
  "fileManifest": {
    "create": [
      {
        "path": "src/infrastructure/gemini.adapter.ts",
        "type": "source",
        "layer": "infrastructure",
        "description": "GeminiAdapter class wrapping Vertex AI SDK"
      },
      {
        "path": "src/infrastructure/__tests__/gemini.adapter.test.ts",
        "type": "test",
        "layer": "infrastructure",
        "description": "Gemini adapter tests with mocked SDK"
      }
    ],
    "modify": [],
    "dependencies": [
      {
        "path": "src/shared/errors.ts",
        "mustExist": true,
        "provides": "AIProcessingError class"
      }
    ]
  },
  "typeDefinitions": {
    "interfaces": [
      {
        "name": "GeminiExtractionResult",
        "description": "Structured output from Gemini reasoning",
        "properties": [
          {
            "name": "intent",
            "type": "string",
            "description": "Primary intent: MEDICAL_TRIAGE, SOS, UTILITY_ISSUE"
          },
          {
            "name": "entities",
            "type": "Record<string, any>",
            "description": "Extracted entities: names, locations, medications, etc."
          },
          {
            "name": "confidence",
            "type": "number",
            "description": "0-1 confidence score"
          }
        ]
      },
      {
        "name": "IGeminiAdapter",
        "description": "Interface for Gemini adapter",
        "methods": [
          {
            "name": "extractIntent",
            "params": "gcsUri: string, mimeType: string",
            "returns": "Promise<GeminiExtractionResult>"
          }
        ]
      }
    ]
  },
  "businessRules": [
    {
      "id": "BR-GEMINI-001",
      "rule": "Gemini response must be valid JSON. If not, throw AIProcessingError.",
      "enforcement": "try/catch around JSON.parse()",
      "errorOnViolation": {
        "code": "AI_PROCESSING_ERROR",
        "status": 502
      }
    },
    {
      "id": "BR-GEMINI-002",
      "rule": "Gemini SDK timeouts must be caught and wrapped in AIProcessingError.",
      "enforcement": "try/catch on generateContent() call",
      "errorOnViolation": {
        "code": "AI_PROCESSING_ERROR",
        "status": 502
      }
    },
    {
      "id": "BR-GEMINI-003",
      "rule": "System prompt must instruct Gemini to ONLY return JSON, no preamble.",
      "enforcement": "Hardcoded system instruction in adapter",
      "errorOnViolation": null
    }
  ],
  "testSpecifications": {
    "unitTests": [
      {
        "suite": "GeminiAdapter",
        "file": "src/infrastructure/__tests__/gemini.adapter.test.ts",
        "cases": [
          {
            "name": "should return structured JSON from Gemini response",
            "type": "happy-path",
            "arrange": "Mock generateContent to return valid JSON string",
            "act": "adapter.extractIntent(uri, mime)",
            "assert": [
              "result.intent is 'MEDICAL_TRIAGE'",
              "result.entities.patient_name is 'John'",
              "result.confidence > 0.9"
            ]
          },
          {
            "name": "should throw AIProcessingError if Gemini returns malformed JSON",
            "type": "error",
            "arrange": "Mock generateContent to return 'This is not JSON'",
            "act": "adapter.extractIntent(uri, mime)",
            "assert": [
              "Throws AIProcessingError"
            ]
          },
          {
            "name": "should throw AIProcessingError on Gemini SDK timeout",
            "type": "error",
            "arrange": "Mock generateContent to reject with DEADLINE_EXCEEDED",
            "act": "adapter.extractIntent(uri, mime)",
            "assert": [
              "Throws AIProcessingError"
            ]
          }
        ]
      }
    ],
    "testData": {
      "fixtures": [
        {
          "name": "validGeminiResponse",
          "data": {
            "intent": "MEDICAL_TRIAGE",
            "entities": {
              "patient_name": "John",
              "allergies": [
                "Sulfites"
              ]
            },
            "confidence": 0.97
          }
        },
        {
          "name": "malformedResponse",
          "data": "This is not JSON at all"
        }
      ]
    }
  },
