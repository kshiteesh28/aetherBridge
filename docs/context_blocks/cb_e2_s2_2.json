  "businessRules": [
    {
      "id": "BR-REASON-001",
      "rule": "Event must exist and be in PENDING status to be processed",
      "enforcement": "Service-level check before calling Gemini",
      "errorOnViolation": {
        "code": "NOT_FOUND",
        "status": 404
      }
    },
    {
      "id": "BR-REASON-002",
      "rule": "Event status transitions: PENDING → PROCESSING → READY_FOR_REVIEW (or FAILED)",
      "enforcement": "Service updates status at each stage",
      "errorOnViolation": null
    },
    {
      "id": "BR-REASON-003",
      "rule": "If Gemini fails, Event status must be set to FAILED",
      "enforcement": "try/catch block in processEvent",
      "errorOnViolation": null
    },
    {
      "id": "BR-REASON-004",
      "rule": "Extracted entity strings must be passed through Cloud DLP before persistence",
      "enforcement": "DLP adapter called after Gemini, before ActionPack creation",
      "errorOnViolation": null
    }
  ],
  "testSpecifications": {
    "unitTests": [
      {
        "suite": "ReasoningService",
        "file": "src/domains/reasoning/__tests__/reasoning.service.test.ts",
        "cases": [
          {
            "name": "should call Gemini, run DLP, create ActionPack, and update Event to READY_FOR_REVIEW",
            "type": "happy-path",
            "arrange": "Mock Gemini to return valid JSON, mock DLP to return cleaned text, mock Prisma",
            "act": "service.processEvent('evt-001')",
            "assert": [
              "Gemini extractIntent called with correct URI",
              "DLP deidentify called",
              "ActionPack created with correct intent",
              "Event updated to READY_FOR_REVIEW",
              "Firestore status synced"
            ]
          },
          {
            "name": "should set Event status to FAILED if Gemini throws",
            "type": "error",
            "arrange": "Mock Gemini to reject with AIProcessingError",
            "act": "service.processEvent('evt-001')",
            "assert": [
              "Event updated to FAILED",
              "Throws error"
            ]
          },
          {
            "name": "should throw NotFoundError if event does not exist",
            "type": "error",
            "arrange": "Mock Prisma findUnique to return null",
            "act": "service.processEvent('ghost-event')",
            "assert": [
              "Throws NotFoundError"
            ]
          }
        ]
      }
    ],
