  "testSpecifications": {
    "unitTests": [
      {
        "suite": "Event Repository (Prisma)",
        "file": "src/domains/intake/__tests__/event.repository.test.ts",
        "cases": [
          {
            "name": "should create an Event with status PENDING",
            "type": "happy-path",
            "arrange": "Valid GCS URI and mediaType",
            "act": "prisma.event.create()",
            "assert": [
              "Event has id",
              "Status is PENDING",
              "Version is 1"
            ]
          },
          {
            "name": "should enforce non-null constraint on rawInputUri",
            "type": "error",
            "arrange": "rawInputUri set to null",
            "act": "prisma.event.create()",
            "assert": [
              "Throws Prisma constraint error"
            ]
          },
          {
            "name": "should create an ActionPack linked to an Event",
            "type": "happy-path",
            "arrange": "Create parent Event first",
            "act": "prisma.actionPack.create()",
            "assert": [
              "ActionPack.eventId matches Event.id",
              "isVerified is false"
            ]
          }
        ]
      }
    ],
    "integrationTests": [],
