  "typeDefinitions": {
    "interfaces": [
      {
        "name": "ActionPackOutput",
        "description": "Standardized Action Pack for relay consumption",
        "properties": [
          {
            "name": "event_id",
            "type": "string"
          },
          {
            "name": "intent",
            "type": "string"
          },
          {
            "name": "entities",
            "type": "Record<string, any>"
          },
          {
            "name": "verification",
            "type": "{ status: 'VERIFIED' | 'REQUIRES_REVIEW', ground_truth_source: string | null }"
          }
        ]
      }
    ]
  },
  "businessRules": [
    {
      "id": "BR-PACK-001",
      "rule": "Confidence >= 0.85 results in verification.status = VERIFIED",
      "enforcement": "ActionPackBuilder.build() threshold check",
      "errorOnViolation": null
    },
    {
      "id": "BR-PACK-002",
      "rule": "Confidence < 0.85 results in verification.status = REQUIRES_REVIEW",
      "enforcement": "ActionPackBuilder.build() threshold check",
      "errorOnViolation": null
    },
    {
      "id": "BR-PACK-003",
      "rule": "Intent field is mandatory in Gemini output. Missing intent throws error.",
      "enforcement": "Validation inside build()",
      "errorOnViolation": {
        "code": "VALIDATION_ERROR",
        "status": 400
      }
    }
  ],
  "testSpecifications": {
    "unitTests": [
      {
        "suite": "ActionPackBuilder",
        "file": "src/domains/reasoning/__tests__/action-pack.builder.test.ts",
        "cases": [
          {
            "name": "should build a valid Action Pack JSON from raw Gemini output",
            "type": "happy-path",
            "arrange": "{ intent: 'MEDICAL_TRIAGE', entities: { patient_name: 'Jane Doe' }, confidence: 0.98 }",
            "act": "ActionPackBuilder.build('evt-001', raw)",
            "assert": [
              "event_id is evt-001",
              "intent is MEDICAL_TRIAGE",
              "verification.status is VERIFIED"
            ]
          },
          {
            "name": "should flag low-confidence packs as REQUIRES_REVIEW",
            "type": "edge-case",
            "arrange": "{ intent: 'UNKNOWN', entities: {}, confidence: 0.4 }",
            "act": "ActionPackBuilder.build('evt-002', raw)",
            "assert": [
              "verification.status is REQUIRES_REVIEW"
            ]
          },
          {
            "name": "should throw if intent is missing from Gemini output",
            "type": "error",
            "arrange": "{ entities: {}, confidence: 0.5 }",
            "act": "ActionPackBuilder.build('evt-003', raw)",
            "assert": [
              "Throws error with message 'Intent is required'"
            ]
          }
        ]
      }
    ],
    "testData": {
      "fixtures": [
        {
          "name": "highConfidence",
          "data": {
            "intent": "MEDICAL_TRIAGE",
            "entities": {
              "patient_name": "Jane Doe",
              "allergies": [
                "Penicillin"
              ]
            },
            "confidence": 0.98
          }
        },
        {
          "name": "lowConfidence",
          "data": {
            "intent": "UNKNOWN",
            "entities": {},
            "confidence": 0.4
          }
        },
        {
          "name": "missingIntent",
          "data": {
            "entities": {},
            "confidence": 0.5
          }
        }
      ]
    }
  },
