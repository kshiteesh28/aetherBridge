  "businessRules": [
    {
      "id": "BR-INTAKE-001",
      "rule": "File buffer must not be empty (0 bytes)",
      "enforcement": "Service-level check before upload",
      "errorOnViolation": {
        "code": "VALIDATION_ERROR",
        "status": 400
      }
    },
    {
      "id": "BR-INTAKE-002",
      "rule": "Only supported MIME types are allowed: audio/*, image/*, video/*",
      "enforcement": "Service-level regex check on mimeType",
      "errorOnViolation": {
        "code": "VALIDATION_ERROR",
        "status": 400
      }
    },
    {
      "id": "BR-INTAKE-003",
      "rule": "Event status must be set to PENDING on creation",
      "enforcement": "Prisma default value in schema",
      "errorOnViolation": null
    },
    {
      "id": "BR-INTAKE-004",
      "rule": "Firestore document must be created for real-time status tracking",
      "enforcement": "Service writes to Firestore after Event creation",
      "errorOnViolation": null
    }
