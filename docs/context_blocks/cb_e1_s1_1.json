        "suite": "IntakeService",
        "file": "src/domains/intake/__tests__/intake.service.test.ts",
        "cases": [
          {
            "name": "should upload file to GCS and create a PENDING event",
            "type": "happy-path",
            "arrange": "Valid Buffer + audio/wav MIME + mocked GCS and Prisma",
            "act": "service.processUpload(input)",
            "assert": [
              "GCS uploadFile called once",
              "Prisma event.create called with status PENDING",
              "Returns eventId and status"
            ]
          },
          {
            "name": "should throw ValidationError if file buffer is empty",
            "type": "error",
            "arrange": "Buffer.alloc(0) + audio/wav",
