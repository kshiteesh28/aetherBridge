  "errorHandling": {
    "errorTypes": [
      {
        "class": "ValidationError",
        "httpStatus": 400,
        "code": "VALIDATION_ERROR",
        "when": "Zod parse failure"
      },
      {
        "class": "NotFoundError",
        "httpStatus": 404,
        "code": "NOT_FOUND",
        "when": "Resource does not exist"
      },
      {
        "class": "AIProcessingError",
        "httpStatus": 502,
        "code": "AI_PROCESSING_ERROR",
        "when": "Gemini timeout or refusal"
      },
      {
        "class": "ConcurrencyError",
        "httpStatus": 409,
        "code": "CONCURRENCY_ERROR",
        "when": "Optimistic lock conflict"
      },
      {
        "class": "ConnectivityError",
        "httpStatus": 503,
        "code": "CONNECTIVITY_ERROR",
        "when": "GCS or DB unreachable"
      }
    ]
  },
  "validationRules": {
